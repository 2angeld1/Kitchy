{
  "expo": {
    "name": "Kitchy",
    "slug": "Kitchy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-premium.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-premium.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Kitchy necesita acceso para que puedas dictarle los productos a registrar.",
        "NSMicrophoneUsageDescription": "Kitchy necesita el micrófono para escuchar tu voz.",
        "NSCameraUsageDescription": "Kitchy necesita acceso a la cámara para escanear códigos de barras."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-premium.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo-premium.png",
      "name": "Kitchy",
      "shortName": "Kitchy",
      "display": "standalone",
      "themeColor": "#000000",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-speech-recognition",
      "expo-camera"
    ]
  }
}